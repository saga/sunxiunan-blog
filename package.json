{
  "name": "sunxiunan blog",
  "type": "module",
  "version": "0.1.1",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "astro dev",
    "full_open_graph_build": "astro build && npx pagefind --site dist && cp -r dist/pagefind public/",
    "build": "SKIP_OG=1 astro build && npx pagefind --site dist && cp -r dist/pagefind public/",
    "build:astro": "SKIP_OG=1 astro build",
    "preview": "astro preview",
    "lint": "biome lint .",
    "format": "pnpm run format:code && pnpm run format:imports",
    "format:code": "biome format . --write && prettier -w \"**/*\" \"!**/*.{md,mdx}\" --ignore-unknown --cache",
    "format:imports": "biome check --formatter-enabled=false --write",
    "astro": "astro",
    "import:wp": "node scripts/import-wordpress.mjs"
  },
  "dependencies": {
    "@astrojs/compiler-rs": "^0.2.2",
    "@astrojs/mdx": "^6.0.3",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.3",
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.3.0",
    "astro": "^6.4.6",
    "glightbox": "^3.3.1",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-slug": "^6.0.0",
    "rehype-unwrap-images": "^1.0.0",
    "remark-gfm": "^4.0.1",
    "satori": "^0.26.0",
    "satori-html": "^0.3.2",
    "tailwindcss": "^4.3.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "pagefind": "^1.5.2",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "turndown": "^7.2.4",
    "turndown-plugin-gfm": "^1.0.2"
  }
}
