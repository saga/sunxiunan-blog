---
import { getEntry, render,} from "astro:content";
import PageLayout from "@/layouts/PageLayout.astro";
import { generateAboutSchema } from "@/utils/schema";
const page = await getEntry( "pages", "about");

if (!page) {
  throw new Error(
    "About page not found."
  );
}

const { Content } = await render(page);
const structuredData = generateAboutSchema(page);
---
<PageLayout entry={page} schema={structuredData}>
  <div class="app-prose page-content">
    <Content />
  </div>
</PageLayout>