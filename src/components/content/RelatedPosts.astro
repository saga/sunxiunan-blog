---
import { type Post } from "@/utils/content";
import SectionHeader from "@/components/SectionHeader.astro";
import ArchiveItem from "@/components/content/ArchiveItem.astro";

type Props = {
  posts: Post[];
  sectionTitle?: string;
  sectionDesc?: string;
};

const {
  posts,
  sectionTitle,
  sectionDesc,
} = Astro.props;

---
<section class="my-2 py-2">
  <SectionHeader title={sectionTitle} subheading={sectionDesc} />
  <div class="flex flex-col space-y-2 mt-4">
    {posts.map((post) => (
      <ArchiveItem post={post} />
    ))}
  </div>
</section>