---
import { getEntry, render } from "astro:content";
import siteConfig from "@/site.config";

const variant = siteConfig.heroVariant;

const homeEntry = await getEntry("pages", "home-intro");
const Content = homeEntry ? (await render(homeEntry)).Content : null;
---
<section class="home-hero flex flex-col pt-8 sm:pt-12" data-pagefind-ignore>
  {variant === "studio" ? (
    <div class="h-px bg-border" />
  ) : (
    <div class="app-prose home-intro-content">
      {Content ? <Content /> : null}
    </div>
  )}
</section>