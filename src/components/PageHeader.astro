---
import { slugify } from '@/utils/text';

interface Props {
  title?: string;
  subheading?: string;
  transitionName?: string;
}
const { title, subheading, transitionName } = Astro.props;
---
<section class="flex flex-col mb-2">
  {title && (
    <h1 
      class="font-content text-3xl leading-tight font-medium md:text-4xl"
      transition:name={transitionName}
    > 
      {title} 
    </h1>
  )}
  {subheading && (
    <p class="mt-2 max-w-xl text-base leading-relaxed italic text-muted-foreground">
      {subheading}
    </p>
  )}
  <div class="mt-2 font-code text-muted-foreground text-[10px]">
    <slot name="meta" />
  </div>
  <div class="divider mb-8" />
</section>
